{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AEGIS Registry",
  "type": "object",
  "required": ["version", "last_updated", "capabilities", "workflow_types", "agents"],
  "properties": {
    "version": { "type": "string" },
    "last_updated": { "type": "string" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "governance_mechanisms", "status"]
      }
    },
    "workflow_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "required_capabilities", "primary_states", "status"]
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "version",
          "entrypoint",
          "enabled",
          "evolution",
          "role",
          "capabilities",
          "workflow_types",
          "allowed_states",
          "contract_actions",
          "inputs",
          "outputs",
          "dependencies",
          "description",
          "metrics"
        ]
      }
    }
  }
}
