{
  "id": "code-reviewer",
  "name": "Code Review Agent",
  "version": "1.3.0",
  "entrypoint": "agents/code-reviewer/SKILL.md",
  "enabled": true,
  "evolution": true,
  "role": "code-reviewer",
  "capabilities": [
    "audit",
    "governance"
  ],
  "workflow_types": [
    "build",
    "audit"
  ],
  "allowed_states": [
    "L3_CODE_REVIEW"
  ],
  "contract_actions": [
    "run_gate_review",
    "run_verification"
  ],
  "inputs": [
    ".aegis/runs/{workflow}/l2-planning/PRD.md",
    ".aegis/runs/{workflow}/l2-planning/task_breakdown.json",
    ".aegis/runs/{workflow}/l2-planning/implementation-contracts.json",
    ".aegis/runs/{workflow}/l3-dev/"
  ],
  "outputs": [
    ".aegis/runs/{workflow}/l3-dev/code-review-report.md",
    ".aegis/runs/{workflow}/l3-dev/review-loop-status.json",
    ".aegis/runs/{workflow}/l3-dev/review-round-{round}.md",
    ".aegis/runs/{workflow}/l3-dev/review-passed.json"
  ],
  "dependencies": [
    "contract:run_gate_review",
    "contract:run_verification"
  ],
  "description": "Independent code quality and architecture reviewer for development artifacts, including DRY compliance and parallel ownership discipline.",
  "metrics": {
    "last_score": 8.0,
    "evolution_count": 0,
    "rollback_count": 0
  }
}
