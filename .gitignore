# AEGIS System Gitignore

# Workspace-local AEGIS runtime artifacts
.aegis/project.yml
.aegis/cache/
.aegis/overrides/
.aegis/policies/
.aegis/runs/
.aegis/runtime-home/
.aegis/state/
.aegis/core/workflow-index.json

# Coverage
.coverage

# Workflow runtime artifacts (keep structure, ignore temp files)
workflows/*/.cache/
workflows/*/.tmp/
workflows/*/node_modules/
workflows/*/__pycache__/
workflows/*/.env
workflows/*/.env.local
# Evolution worktrees and temp files
*.evolution-result.json
/tmp/aegis-evolution/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Dependencies
node_modules/

__pycache__/
*.pyc

# Keep workflow directories themselves
!workflows/.gitkeep
